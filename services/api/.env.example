ZENBAR_DATABASE_URL=sqlite:///./zenbar.db
ZENBAR_RUNTIME_MODE=app_server_ws
ZENBAR_APP_SERVER_WS_URL=ws://127.0.0.1:8765
ZENBAR_APP_SERVER_MANAGED=true
ZENBAR_APP_SERVER_COMMAND=codex
ZENBAR_WORKSPACE_ROOT=/tmp/zenbar-task-workspaces
ZENBAR_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Optional: set a token to allow authenticated remote access.
# When unset, only loopback clients are allowed unless ZENBAR_ALLOW_UNAUTHENTICATED_REMOTE=true.
ZENBAR_API_TOKEN=
ZENBAR_ALLOW_UNAUTHENTICATED_REMOTE=false
